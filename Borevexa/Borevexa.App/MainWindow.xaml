                                    <Border x:Name="StepSurfaceAnalysisPanel" Grid.Row="2" Visibility="Collapsed" Background="White" BorderBrush="#DEE6EA" BorderThickness="1" CornerRadius="4" Margin="0,10,0,0" Padding="12">
