                                                    <Button Content="Opslaan" Visibility="Collapsed" DockPanel.Dock="Right" HorizontalAlignment="Right" Background="#3F4750" Foreground="White" BorderThickness="0" Padding="14,7" Margin="12,0,0,0" Click="SaveReportPreviewPart_OnClick"/>
