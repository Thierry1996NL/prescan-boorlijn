        <Grid x:Name="ProjectsPagePanel" Grid.Row="1" Grid.Column="2" Margin="38,42,46,0" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


    <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Projecten" FontSize="26" FontWeight="Bold" Foreground="#071422"/>
                    <TextBlock x:Name="ProjectCountText" Text="0 projecten" Foreground="#8FA6B2" FontSize="18" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Nieuw project" Background="#3F4750" Foreground="White" BorderThickness="0" Padding="18,12" Margin="0" FontSize="16" FontWeight="SemiBold" Click="NewProject_OnClick"/>
            </Grid>

            <Border Grid.Row="1" BorderBrush="#DEE6EA" BorderThickness="1" CornerRadius="4" Background="White" Margin="0,28,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Background="#F8FAFB" Margin="0" Height="52">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="PROJECT" Foreground="#8FA6B2" FontWeight="Bold" FontSize="13" Margin="26,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="OPDRACHTGEVER" Foreground="#8FA6B2" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="LOCATIE" Foreground="#8FA6B2" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="STATUS" Foreground="#8FA6B2" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                    </Grid>
                    <ListBox x:Name="ProjectsPageList"
                             Grid.Row="1"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionChanged="ProjectsPageList_OnSelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EEF2F5" BorderThickness="0,0,0,1">
                                    <Grid MinHeight="76" Margin="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="26,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="#071422"/>
                                            <TextBlock Foreground="#8FA6B2" FontSize="13" Margin="0,5,0,0">
                                                <Run Text="{Binding BoreLengthMeters, StringFormat={}{0:0.#} m}"/>
                                                <Run Text=" · Ø"/>
                                                <Run Text="{Binding DiameterMillimeters}"/>
                                                <Run Text=" mm · "/>
                                                <Run Text="{Binding Material}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Client}" Foreground="#1B2B35" FontSize="15" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Location}" Foreground="#1B2B35" FontSize="15" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="3" Background="#EEF2F5" CornerRadius="4" Padding="9,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Status}" Foreground="#4B5563" FontSize="13" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Grid.Column="4" Text="selecteer" Foreground="#8FA6B2" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Border Grid.Row="2" Background="#F8FAFB" BorderBrush="#DEE6EA" BorderThickness="0,1,0,0" Padding="18,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="ProjectsPageSelectedProjectNameText" Text="Geen project geselecteerd" FontSize="15" FontWeight="SemiBold" Foreground="#071422"/>
                                <TextBlock x:Name="ProjectsPageSelectedProjectDetailsText" Text="Selecteer een project om het te openen of te verwijderen." Foreground="#587080" FontSize="13" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                                <Button x:Name="OpenSelectedProjectButton" Content="Project openen" IsEnabled="False" Background="#3F4750" Foreground="White" BorderBrush="#3F4750" BorderThickness="1" Padding="14,8" Margin="0,0,8,0" FontWeight="SemiBold" Click="OpenSelectedProject_OnClick"/>
                                <Button x:Name="DeleteSelectedProjectButton" Content="Project verwijderen" IsEnabled="False" Background="#FEF2F2" Foreground="#B91C1C" BorderBrush="#FCA5A5" BorderThickness="1" Padding="14,8" FontWeight="SemiBold" Click="DeleteSelectedProject_OnClick"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="2" Background="White" BorderBrush="#DEE6EA" BorderThickness="1,0,0,0" Visibility="Collapsed">
            <ScrollViewer>
                <StackPanel Margin="22">
                    <TextBlock Text="Acties" FontSize="18" FontWeight="Bold" Foreground="#0D1520"/>
                    <TextBlock x:Name="ActionsSubtitle" Text="Stap-specifieke acties" Foreground="#587080" Margin="0,4,0,18"/>

                    <StackPanel x:Name="ActionButtonsPanel"/>

                    <Border Style="{StaticResource Panel}" Padding="14" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Output" FontWeight="SemiBold"/>
                            <TextBlock x:Name="OutputText" TextWrapping="Wrap" Foreground="#587080" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>




















