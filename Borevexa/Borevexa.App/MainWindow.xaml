                                    <StackPanel>
                                        <DockPanel Background="#F7F9FB" LastChildFill="True" Margin="0" Height="58">
                                            <Button x:Name="FinalReportExportButton" Content="Concept exporteren" DockPanel.Dock="Right" Background="#3F4750" Foreground="White" BorderThickness="0" Padding="18,9" Margin="0,10,14,10" FontWeight="SemiBold" Click="FinalReportExport_OnClick"/>
                                            <Button x:Name="FinalReportRegenerateButton" Content="Rapportdata verversen" DockPanel.Dock="Right" Background="White" Foreground="#3F4750" BorderBrush="#CBD5E1" BorderThickness="1" Padding="14,9" Margin="0,10,10,10" FontWeight="SemiBold" Click="FinalReportRegenerate_OnClick"/>
                                            <StackPanel Margin="18,9,12,6">
                                                <TextBlock x:Name="ReportPreviewTitleText" Text="Eindrapportage - automatische rapportpreview" Foreground="#071422" FontSize="15" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="ReportExportHintText" Text="Rapport wordt gevuld uit opgeslagen stapdata. Genereer opnieuw haalt de laatste stapgegevens op." Foreground="#748494" FontSize="11" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </DockPanel>

                                        <Border x:Name="ReportPartEditorPanel" Visibility="Collapsed" Background="#FBFCFD" BorderBrush="#D7E8FA" BorderThickness="0,1,0,1" Padding="18,12">
