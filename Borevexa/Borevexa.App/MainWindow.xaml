<Window x:Class="Borevexa.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Borevexa"
        Height="730"
        Width="1220"
        MinHeight="620"
        MinWidth="940"
        Background="#F3F6FA"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="BvGreen" Color="#3F4750"/>
        <SolidColorBrush x:Key="BvAccent" Color="#2563EB"/>
        <SolidColorBrush x:Key="BvDark" Color="#0D1520"/>
        <SolidColorBrush x:Key="BvText" Color="#0F172A"/>
        <SolidColorBrush x:Key="BvSurface" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BvSoftSurface" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="BvBorder" Color="#DCE5EC"/>
        <SolidColorBrush x:Key="BvMuted" Color="#587080"/>
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BvSurface}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BvBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BvBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FAFB"/>
            <Setter Property="Foreground" Value="{StaticResource BvText}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#AFC8E5"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#60A5FA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.86"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.48"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.012" Duration="0:0:0.10"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.012" Duration="0:0:0.10"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.12"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource BvText}"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource BvText}"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource BvText}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="Border">
            <Setter Property="Background" Value="#F7FAFC"/>
            <Setter Property="BorderBrush" Value="#E3ECF3"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style x:Key="SectionBadge" TargetType="Border">
            <Setter Property="Width" Value="17"/>
            <Setter Property="Height" Value="17"/>
            <Setter Property="CornerRadius" Value="8.5"/>
            <Setter Property="Background" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#0A1B2A"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>


    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="340" MinWidth="54" MaxWidth="386"/>
            <ColumnDefinition x:Name="SidebarSplitterColumn" Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#FFFFFF" BorderBrush="#E5EAF0" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="0,0,10,0" VerticalAlignment="Center">
                    <Button x:Name="PreviousStepButton" Content="← Vorige" IsEnabled="False" Padding="9,3" Margin="0,0,6,0" Background="White" Foreground="#587080" BorderBrush="#DEE6EA" BorderThickness="1" FontSize="12" Click="PreviousStep_OnClick"/>
                    <Button x:Name="NextStepButton" Content="Volgende →" IsEnabled="False" Padding="10,3" Margin="0,0,6,0" Background="#3F4750" Foreground="White" BorderBrush="#3F4750" BorderThickness="1" FontSize="12" Click="NextStep_OnClick"/>
                    <Button x:Name="SubstepReportPreviewButton" Content="Substap preview" Visibility="Collapsed" Padding="9,3" Margin="0,0,6,0" Background="White" Foreground="#315B7E" BorderBrush="#BFD7F1" BorderThickness="1" FontSize="12" Click="SubstepReportPreview_OnClick"/>
                    <Button x:Name="ChapterReportPreviewButton" Content="Hoofdstuk preview" Visibility="Collapsed" Padding="9,3" Margin="0,0,8,0" Background="White" Foreground="#315B7E" BorderBrush="#BFD7F1" BorderThickness="1" FontSize="12" Click="ChapterReportPreview_OnClick"/>
                    <Button x:Name="KnowledgeLibraryButton" ToolTip="Documentatiebibliotheek voor normen en richtlijnen" Visibility="Collapsed" Width="34" Height="24" Padding="0" Margin="0,0,8,0" Background="White" Foreground="#315B7E" BorderBrush="#BFD7F1" BorderThickness="1" Click="KnowledgeLibrary_OnClick">
                        <TextBlock Text="&#x1F4DA;" FontFamily="Segoe UI Emoji" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="ToggleStepFilterButton" Content="Zijbalk" Visibility="Collapsed" Padding="9,3" Margin="0,0,8,0" Background="White" Foreground="#315B7E" BorderBrush="#BFD7F1" BorderThickness="1" FontSize="12" Click="ToggleStepFilterSidebar_OnClick"/>
                    <Button x:Name="TopProjectSaveButton" Content="Project opslaan" Padding="12,4" Margin="0" Background="#3F4750" BorderBrush="#3F4750" BorderThickness="1" Foreground="White" FontSize="12" FontWeight="SemiBold" Click="TopProjectSave_OnClick"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="8,0,0,0" VerticalAlignment="Center">
                    <Button x:Name="TopProjectsButton" Content="Projecten" Padding="9,3" Margin="0" Background="#F1F5F7" BorderBrush="#E1E7EA" BorderThickness="1" Foreground="#3F5664" FontSize="12" Click="ShowProjectsPage_OnClick"/>
                    <Button x:Name="TopActiveProjectButton" Content="Geen project" Padding="9,3" Margin="10,0,0,0" Background="Transparent" BorderThickness="0" Foreground="#3F4750" FontSize="12" FontWeight="Normal" Click="ShowProjectsPage_OnClick"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="SidebarBorder" Grid.Row="1" Grid.Column="0" Background="#F8FAFC" BorderBrush="#DCE5EC" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderBrush="#DEE6EA" BorderThickness="0,0,0,1" Padding="12,8">

    <Grid x:Name="SidebarHeaderGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel x:Name="SidebarMainTabsPanel" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="SidebarStepsModeButton" Content="Processtappen" Tag="steps" Height="28" Padding="10,0" Margin="0,0,6,0" FontSize="12" FontWeight="SemiBold" Background="#DBEAFE" Foreground="#174A7C" BorderBrush="#BFDBFE" BorderThickness="1" Click="SidebarMainMode_OnClick"/>
                            <Button x:Name="SidebarInfoModeButton" Content="Procesinfo" Tag="info" Height="28" Padding="10,0" Margin="0" FontSize="12" FontWeight="SemiBold" Background="White" Foreground="#315B7E" BorderBrush="#D8E6F3" BorderThickness="1" Click="SidebarMainMode_OnClick"/>
                        </StackPanel>
                        <TextBlock x:Name="SidebarPanelTitle" Text="Processtappen" Foreground="#3F5664" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Visibility="Collapsed"/>
                        <Image x:Name="SidebarLogoImage" Source="Assets/Brand/borevexa-logo.png" Height="0" Width="0" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed"/>
                        <Button x:Name="SidebarToggleButton" Grid.Column="1" Content="&lt;" Foreground="#8FA6B2" Background="Transparent" BorderThickness="0" Padding="4" Margin="8,0,0,0" FontSize="13" Click="SidebarToggle_OnClick"/>
                    </Grid>
                </Border>

                <ContentControl x:Name="UnifiedStepContextHost"
                                Grid.Row="2"
                                Visibility="Collapsed"
                                Margin="8,10,8,0"/>

                <Grid x:Name="SidebarMainContent" Grid.Row="2" Margin="8,10,8,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <ListBox x:Name="ProjectsList"
                             Visibility="Collapsed"
                             Height="0"
                             Margin="0"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#071422"
                             SelectionChanged="ProjectsList_OnSelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#DEE6EA" BorderThickness="1" CornerRadius="4" Padding="9,7" Margin="0,0,0,5" Background="#F8FAFB">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Location}" Foreground="#8FA6B2" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ListBox x:Name="SideStepsList"
                             Grid.Row="1"
                             Margin="0"
                             Padding="0"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#071422"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="StepsList_OnSelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="IsEnabled" Value="{Binding IsSelectable}"/>
                                <Setter Property="Focusable" Value="{Binding IsSelectable}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                            <Border x:Name="ItemChrome" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemChrome" Property="Background" Value="#EFF6FF"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemChrome" Property="Background" Value="#DBEAFE"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.58"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="2" Padding="6,3" Margin="0">

    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding DisplayText}" FontSize="12" Foreground="{Binding TitleBrush}" VerticalAlignment="Center" Margin="{Binding ItemMargin}" FontWeight="{Binding TitleWeight}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </Grid>

                <ListBox x:Name="SidebarCompactStepsList"
                         Grid.Row="2"
                         Visibility="Collapsed"
                         Margin="6,8,5,0"
                         Padding="0,0,5,0"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="StepsList_OnSelectionChanged">
                    <ListBox.Resources>
                        <Style TargetType="{x:Type ScrollBar}">
                            <Setter Property="Width" Value="7"/>
                            <Setter Property="MinWidth" Value="7"/>
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,1"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                        <Border x:Name="ItemChrome" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemChrome" Property="Background" Value="#EFF6FF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemChrome" Property="Background" Value="#DBEAFE"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="2" Padding="0" Margin="{Binding CompactItemMargin}">
                                <TextBlock Text="{Binding CompactDisplayText}" FontSize="{Binding CompactFontSize}" Foreground="{Binding TitleBrush}" FontWeight="{Binding TitleWeight}" HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </Grid>
        </Border>

        <GridSplitter x:Name="SidebarSplitter"
                      Grid.Row="1"
                      Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#EEF2F4"
                      ShowsPreview="True"/>

        <Grid x:Name="WorkflowPanel" Grid.Row="1" Grid.Column="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="StepFilterColumn" Width="0"/>
                <ColumnDefinition x:Name="ReportPreviewSplitterColumn" Width="0"/>
                <ColumnDefinition x:Name="ReportPreviewColumn" Width="0"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#DCE5EC" BorderThickness="0,0,0,1" Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="StepCounterText" Text="Stap 1 van 10" Foreground="#8FA6B2" FontSize="13"/>
                        <WrapPanel Margin="0,2,0,0">
                            <TextBlock x:Name="StepHeaderTitle" Text="Projectinformatie" Foreground="#071422" FontSize="16" FontWeight="Normal" Margin="0,2,16,4"/>
                            <WrapPanel x:Name="WorkflowSubstepsPanel" Margin="0,0,0,0"/>
                        </WrapPanel>
                    </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="HeaderStepSaveButton" Content="Project opslaan" Visibility="Collapsed" Background="White" Foreground="#315B7E" BorderBrush="#BFD7F1" BorderThickness="1" Padding="12,6" Margin="0,0,8,0" FontWeight="SemiBold" Click="HeaderStepSave_OnClick"/>
                            <Button x:Name="HeaderMapSaveButton" Content="Opslaan voor rapportage" Visibility="Collapsed" Background="#334155" Foreground="White" BorderThickness="0" Padding="14,6" Margin="0" FontWeight="SemiBold" Click="MapSave_OnClick"/>
                        </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="WorkflowReportStatusBar" Grid.Row="1" Grid.Column="0" Background="#F8FAFC" BorderBrush="#DCE5EC" BorderThickness="0,0,0,1" Padding="12,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0" Visibility="Collapsed">
                        <TextBlock Text="Stapdata" Foreground="#8FA6B2" FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock x:Name="WorkflowStepDataStatusText" Text="-" Foreground="#071422" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="16,0,0,0" Visibility="Collapsed">
                        <TextBlock Text="Rapportdata" Foreground="#8FA6B2" FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock x:Name="WorkflowReportDataStatusText" Text="-" Foreground="#071422" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="16,0,0,0" Visibility="Collapsed">
                        <TextBlock Text="Kaartbeeld" Foreground="#8FA6B2" FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock x:Name="WorkflowMapStatusText" Text="-" Foreground="#071422" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="16,0,0,0" Visibility="Collapsed">
                        <TextBlock Text="Laatste eindrapport" Foreground="#8FA6B2" FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock x:Name="WorkflowReportGeneratedText" Text="-" Foreground="#071422" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                    <DockPanel x:Name="WorkflowPartsHost" Grid.Row="1" Grid.ColumnSpan="4" Margin="0,2,0,0">
                        <TextBlock Text="Onderdelen" DockPanel.Dock="Left" Foreground="#8FA6B2" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,3"/>
                        <WrapPanel x:Name="WorkflowPartsPanel"/>
                    </DockPanel>
                    <Border Grid.Row="2" Grid.ColumnSpan="4" Margin="0,6,0,0" Background="#FFFFFF" BorderBrush="#E3ECF3" BorderThickness="1" CornerRadius="6" Padding="8,6" Visibility="Collapsed">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Rapportcontrole" DockPanel.Dock="Left" Foreground="#8FA6B2" FontSize="10" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                <TextBlock x:Name="WorkflowReportQualityText" Text="-" Foreground="#071422" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            </DockPanel>
                            <TextBlock x:Name="WorkflowReportQualityActionsText" Text="" Foreground="#587080" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="GlobalBusyIndicator" Grid.Row="3" Grid.ColumnSpan="4" Visibility="Collapsed" Margin="0,6,0,0" Background="#FFFFFF" BorderBrush="#BFD7F1" BorderThickness="1" CornerRadius="6" Padding="8,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="GlobalBusyText" Text="Bezig..." Foreground="#315B7E" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            <ProgressBar Grid.Column="1" Height="5" IsIndeterminate="True" Foreground="#315B7E" Background="#EAF3FA" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="StepRibbonHost" Grid.Row="2" Grid.Column="0" Visibility="Collapsed" Background="#FFFFFF" BorderBrush="#DCE5EC" BorderThickness="0,0,0,1" Padding="10,8">
                <DockPanel>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="190">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="StepSpecificRibbonBorder" MinWidth="200" MaxWidth="320" BorderBrush="#EEF2F4" BorderThickness="0,0,1,0" Padding="8,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="Tools" Foreground="#587080" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6"/>
                                    <StackPanel x:Name="StepSpecificRibbonPanel"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border x:Name="StepFilterSidebar" Grid.Row="0" Grid.RowSpan="4" Grid.Column="1" Visibility="Collapsed" Background="#F8FAFC" BorderBrush="#D9E2EA" BorderThickness="1,0,0,0" Padding="10">
                <DockPanel LastChildFill="True">
                    <WrapPanel x:Name="SidebarToolsTabsPanel" DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Button x:Name="SidebarReportInfoTab" Content="Rapportinfo" Tag="reportInfo" Height="30" Padding="9,0" Margin="0,0,6,6" FontWeight="SemiBold" Click="SidebarTab_OnClick"/>
                        <Button x:Name="SidebarIntroductionTab" Content="Inleiding" Tag="introduction" Height="30" Padding="10,0" Margin="0,0,6,6" FontWeight="SemiBold" Visibility="Collapsed" Click="SidebarTab_OnClick"/>
                        <Button x:Name="SidebarKnowledgeTab" Content="Documentatie" Tag="knowledge" Height="30" Padding="10,0" Margin="0,0,6,6" FontWeight="SemiBold" Click="SidebarTab_OnClick"/>
                        <Button x:Name="SidebarProjectInfoTab" Content="Projectinfo" Tag="projectInfo" Height="30" Padding="9,0" Margin="0,0,6,6" FontWeight="SemiBold" Click="SidebarTab_OnClick"/>
